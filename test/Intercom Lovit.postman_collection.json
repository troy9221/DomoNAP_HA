		{
			"name": "ConfirmAuthorization",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"let responseData = pm.response.json();",
							"",
							"pm.collectionVariables.set(\"accessToken\", \"Bearer \" + responseData.completeToken.accessToken);",
							"pm.collectionVariables.set(\"refreshToken\", responseData.completeToken.refreshToken);",
							"pm.collectionVariables.set(\"refreshExpirationDate\", responseData.completeToken.refreshExpirationDate);"
