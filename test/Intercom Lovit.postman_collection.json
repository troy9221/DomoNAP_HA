	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"const guid = () => pm.variables.replaceIn(\"{{$guid}}\");",
					"const compactGuid = () => guid().replace(/-/g, \"\");",
					"",
					"if (!pm.collectionVariables.get(\"instanceId\")) {",
					"  pm.collectionVariables.set(\"instanceId\", guid());",
					"}",
					"",
					"if (!pm.collectionVariables.get(\"deviceToken\")) {",
					"  pm.collectionVariables.set(\"deviceToken\", `${compactGuid().slice(0, 22)}:APA91b${compactGuid()}${compactGuid()}${compactGuid()}${compactGuid()}`);",
					"}"
				]
			}
		},
